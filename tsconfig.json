{
  "compilerOptions": {
    "target": "ESNext",
    "module": "CommonJS",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "types": ["@playwright/test", "node"],
    "outDir": "dist",
    "rootDir": ".",
    "paths": {
      "@helpers/*": ["./helpers/*"]
    }
  },
  "include": ["tests/**/*", "playwright.config.ts", "helpers/**/*"],
  "exclude": ["node_modules", "dist"]
}
