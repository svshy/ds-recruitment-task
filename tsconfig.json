{
  "compilerOptions": {
    "target": "ESNext",
    "module": "CommonJS",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "types": ["@playwright/test", "node"],
    "outDir": "dist",
    "rootDir": ".",
    "paths": {
      "@helpers/*": ["./helpers/*"],
      "@pages/*": ["./pages/*"],
      "@fixtures/*": ["./fixtures/*"],
      "@components/*": ["./components/*"]
    }
  },
  "include": ["tests/**/*", "playwright.config.ts", "helpers/**/*", "pages/**/*", "fixtures/**/*", "components/**/*"],
  "exclude": ["node_modules", "dist"]
}
